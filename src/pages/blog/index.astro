import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Writing — Aditya Jain</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Mono:wght@300;400;500&family=Instrument+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:#0a0a08;--surface:#111110;--surface2:#1a1a17;--border:#2a2a26;
      --accent:#c8f04a;--text:#e8e8e2;--muted:#6b6b65;
      --serif:'Playfair Display',serif;--mono:'DM Mono',monospace;--sans:'Instrument Sans',sans-serif;
    }
    body { background:var(--bg); color:var(--text); font-family:var(--sans); }
    nav {
      padding:1.4rem 3rem; border-bottom:1px solid var(--border);
      display:flex; justify-content:space-between; align-items:center;
    }
    .nav-logo { font-family:var(--serif);font-style:italic;color:var(--text);text-decoration:none;font-size:1.1rem; }
    .nav-home { font-family:var(--mono);font-size:0.7rem;color:var(--muted);text-decoration:none;text-transform:uppercase;letter-spacing:0.1em;transition:color 0.2s; }
    .nav-home:hover { color:var(--accent); }
    header { padding:6rem 3rem 4rem; border-bottom:1px solid var(--border); }
    .eyebrow { font-family:var(--mono);font-size:0.7rem;color:var(--accent);text-transform:uppercase;letter-spacing:0.15em;margin-bottom:1rem; }
    h1 { font-family:var(--serif);font-size:clamp(2.5rem,6vw,5rem);font-weight:900;line-height:1.05;letter-spacing:-0.02em; }
    .post-list { max-width:900px; margin:0 auto; padding:0 3rem 8rem; }
    .post-item {
      display:grid; grid-template-columns:120px 1fr auto;
      gap:2rem; align-items:start;
      padding:2.5rem 0; border-bottom:1px solid var(--border);
      text-decoration:none; color:inherit;
      transition:background 0.2s;
    }
    .post-item:hover .post-title { color:var(--accent); }
    .post-date { font-family:var(--mono);font-size:0.65rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em;padding-top:0.3rem; }
    .post-title { font-family:var(--serif);font-size:1.4rem;font-weight:700;line-height:1.2;transition:color 0.2s;margin-bottom:0.5rem; }
    .post-desc { color:var(--muted);font-size:0.88rem;line-height:1.6;font-weight:300; }
    .post-arrow { color:var(--muted);font-size:1.2rem;transition:transform 0.2s,color 0.2s;padding-top:0.2rem; }
    .post-item:hover .post-arrow { transform:translate(4px,-4px);color:var(--accent); }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="nav-logo">Aditya Jain</a>
    <a href="/" class="nav-home">← Home</a>
  </nav>
  <header>
    <div class="eyebrow">Writing</div>
    <h1>My thinking,<br>out loud.</h1>
  </header>
  <div class="post-list">
    {posts.map(post => (
      <a href={`/blog/${post.slug}/`} class="post-item">
        <div class="post-date">{new Date(post.data.pubDate).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}</div>
        <div>
          <div class="post-title">{post.data.title}</div>
          {post.data.description && <div class="post-desc">{post.data.description}</div>}
        </div>
        <div class="post-arrow">↗</div>
      </a>
    ))}
  </div>
</body>
</html>
